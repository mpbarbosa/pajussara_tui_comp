# ── Test runner image for pajussara_tui_comp ─────────────────────────────────
#
# Build and run:
#   docker build -f Dockerfile.test -t pajussara_tui_comp-test .
#   docker run --rm pajussara_tui_comp-test
#
# Run with coverage:
#   docker run --rm \
#     -v "$(pwd)/coverage:/app/coverage" \
#     pajussara_tui_comp-test \
#     npm test -- --coverage
# ─────────────────────────────────────────────────────────────────────────────

FROM node:22-alpine

# Build tools required by native npm add-ons (e.g. node-gyp)
RUN apk add --no-cache python3 make g++

WORKDIR /app

# Copy dependency manifests first so this layer is cached between source changes
COPY package.json package-lock.json ./

# Install all dependencies (devDependencies are needed for Jest + ts-jest).
# node:22-alpine ships with NODE_ENV=production which causes npm ci to skip
# devDependencies. Override it here so the full dependency tree is installed.
# --ignore-scripts skips post-install scripts that may fail inside Alpine.
ENV NODE_ENV=test
RUN npm ci --ignore-scripts

# Copy the rest of the project (respects .dockerignore)
COPY . .

# Run the full Jest suite by default
CMD ["npm", "test"]
