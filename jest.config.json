{
  "preset": "ts-jest/presets/default-esm",
  "extensionsToTreatAsEsm": [".ts", ".tsx"],
  "testEnvironment": "node",
  "roots": ["<rootDir>/test"],
  "testMatch": ["**/*.test.ts", "**/*.test.tsx"],
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", { "useESM": true }]
  },
  "collectCoverageFrom": ["src/**/*.{ts,tsx}", "helpers/**/*.ts"],
  "coverageThreshold": {
    "global": {
      "lines": 80
    }
  }
}
